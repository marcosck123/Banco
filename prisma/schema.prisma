// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Expense {
  id          String   @id @default(cuid())
  amount      Float
  description String
  paidBy      String   // "user1" or "user2"
  category    String
  date        DateTime
  splitType   String   @default("shared") // "shared" | "user1_only" | "user2_only"
  createdAt   DateTime @default(now())
}

model Payment {
  id          String   @id @default(cuid())
  amount      Float
  user1Amount Float    @default(0)
  user2Amount Float    @default(0)
  month       Int
  year        Int
  paidAt      DateTime @default(now())
}

model Settings {
  id           String @id @default("default")
  creditLimit  Float  @default(65000)
  user1Name    String @default("Você")
  user2Name    String @default("Namorada")
}
